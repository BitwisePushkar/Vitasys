# --- CORE SETTINGS ---
SECRET_KEY="your-super-secret-key-change-me"
DEBUG=True
ALLOWED_HOSTS="localhost,127.0.0.1,*"
TIME_ZONE="UTC"

# --- DATABASE (PostgreSQL) ---
# Set DATABASE_URL for production or use individual variables for local setup
DATABASE_URL="postgres://vitasysadmin:vitasys2025@db:5432/vitasysdata"
POSTGRES_DB="vitasysdata"
POSTGRES_USER="vitasysadmin"
POSTGRES_PASSWORD="vitasys2025"
POSTGRES_HOST="db"
POSTGRES_PORT="5432"

# --- CACHE & REAL-TIME (Redis) ---
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_PASSWORD=""

# --- EMAIL CONFIGURATION (SMTP) ---
EMAIL_BACKEND="django.core.mail.backends.smtp.EmailBackend"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER="your-email@gmail.com"
EMAIL_HOST_PASSWORD="your-app-specific-password"

# --- SECURITY & JWT ---
JWT_ACCESS_TOKEN_LIFETIME_HOURS=1
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30
SECURE_SSL_REDIRECT=False
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS="SAMEORIGIN"

# --- AWS STORAGE (S3) ---
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_STORAGE_BUCKET_NAME="vitasys-media-bucket"

# --- APPLICATION LIMITS & TIMEOUTS ---
LOG_LEVEL="INFO"
OTP_EXPIRY_MINUTES=3
OTP_MAX_ATTEMPTS=5
LOGIN_MAX_ATTEMPTS=5
OTP_LOCK_DURATION_MINUTES=15
LOGIN_LOCK_DURATION_MINUTES=15
PAGE_SIZE=50

# --- INFRASTRUCTURE ---
RUNNING_IN_DOCKER=True